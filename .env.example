# ════════════════════════════════════════════════════════════
#  КОНФИГУРАЦИЯ ПРИЛОЖЕНИЯ
# ════════════════════════════════════════════════════════════

# ─── Авторизация (обязательно) ───────────────────────────
# Секрет для подписи cookie админа. Установите длинную случайную строку!
# Сгенерировать: openssl rand -hex 32
ADMIN_SECRET="change-me-to-a-long-random-secret"

# ════════════════════════════════════════════════════════════
#  ЛОКАЛЬНАЯ РАЗРАБОТКА (SQLite)
# ════════════════════════════════════════════════════════════
# Скопируйте этот блок в .env (без EXAMPLE) для локальной разработки.
# Используется prisma/schema.prisma (provider = "sqlite").

DATABASE_URL="file:./db/custom.db"

# ════════════════════════════════════════════════════════════
#  PRODUCTION (Vercel + PostgreSQL)
# ════════════════════════════════════════════════════════════
# Эти переменные нужно задать в Vercel Project Settings → Environment Variables.
# Используется prisma/schema.prod.prisma (provider = "postgresql").
#
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public&sslmode=require"
#
# Примеры подключения:
#
# ─── Neon (https://neon.tech) — рекомендовано, бесплатно для старта ───
# DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/marketing_bureau?schema=public&sslmode=require"
#
# ─── Supabase (https://supabase.com) ───
# DATABASE_URL="postgresql://postgres.xxxx:pass@db.xxxx.supabase.co:5432/postgres?schema=public"
#
# ─── Vercel Postgres (https://vercel.com/docs/storage/vercel-postgres) ───
# DATABASE_URL="postgres://default:pass@db-postgres-xxx.region.db.vercel.com:5432/db?sslmode=require"
#
# ВАЖНО: на Vercel не задавайте DATABASE_PROVIDER — используется
# явный флаг --schema=prisma/schema.prod.prisma в vercel-build скрипте.

# ════════════════════════════════════════════════════════════
#  ОПЦИОНАЛЬНЫЕ ПЕРЕМЕННЫЕ
# ════════════════════════════════════════════════════════════

# ─── Базовый URL сайта (для sitemap, OG-метаданных, canonical) ───
# На Vercel автоматически доступна NEXT_PUBLIC_VERCEL_URL, но
# лучше задать явный production-домен после привязки своего домена.
# SITE_URL="https://marketingbureau.kz"

# ─── Telegram Bot (токен берётся из БД по умолчанию, можно переопределить) ───
# TELEGRAM_BOT_TOKEN="123456:ABC-DEF..."
